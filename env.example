# ============================================================================
# .env.example - пример конфига (переименуй в .env и заполни свои значения)
# ============================================================================

# OKX API КЛЮЧИ
# Получи на https://www.okx.com/account/api
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# TELEGRAM NOTIFICATIONS
# Создай бота у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ПАРАМЕТРЫ КОПИ-ТРЕЙДИНГА
COPY_RATIO=0.05                 # 5% от позиции трейдера (начни с малого!)
MIN_TRADER_ROI=100              # Минимальный ROI трейдера
MIN_TRADER_DAYS=90              # Минимум дней активности
MAX_TRADERS=5                   # Макс количество копируемых трейдеров
CHECK_INTERVAL=30               # Интервал проверки (сек)

# УПРАВЛЕНИЕ РИСКАМИ
STOP_LOSS_PERCENT=5.0           # Стоп-лосс 5%
MAX_DRAWDOWN=15.0               # Макс просадка депо
MAX_OPEN_POSITIONS=10           # Макс открытых позиций
MIN_BALANCE=100.0               # Мин баланс для торговли (USDT)

# ТОРГОВЫЕ ПАРЫ (пусто = все, или перечисли через запятую)
ALLOWED_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT
EXCLUDED_PAIRS=USDT/USDC,BUSD/USDT

# ЛОГИРОВАНИЕ
LOG_DIR=./logs
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR

# БА ЗА
DB_PATH=./data/trades.db

# РЕЖИМЫ
PAPER_TRADING=True              # True = тестирование без реальных денег
DEBUG_MODE=False                # True = подробное логирование

# ФИЛЬТРЫ ТРЕЙДЕРОВ
MIN_MONTHLY_ROI=5.0             # Минимальный ROI за месяц
MAX_STRATEGY_VOLATILITY=30.0    # Макс волатильность стратегии
MIN_SUCCESSFUL_TRADES=10        # Мин количество успешных трейдов
